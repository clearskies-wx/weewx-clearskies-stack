# Clear Skies — environment variable template
# Copy this file to .env and fill in the required values.
# Lines marked REQUIRED must be set before starting the stack.

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------

# REQUIRED — the public hostname Caddy will serve and obtain a TLS cert for.
# For local testing you can use "localhost" (Caddy will use a self-signed cert).
CLEARSKIES_DOMAIN=weather.example.com

# ---------------------------------------------------------------------------
# Image versions
# ---------------------------------------------------------------------------

# All three service images (api, realtime, dashboard) are pulled at this tag.
CLEARSKIES_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Config and secrets paths
# ---------------------------------------------------------------------------

# Directory on the host containing api.conf and realtime.conf.
# Mounted read-only into the api and realtime containers.
CLEARSKIES_CONFIG_DIR=./config

# File containing runtime secrets (API keys, proxy secret, etc.).
# Loaded as env_file by both api and realtime containers.
# Never commit this file — add it to .gitignore.
CLEARSKIES_SECRETS_FILE=./config/secrets.env

# ---------------------------------------------------------------------------
# weewx data paths (bind-mounted into the api container)
# ---------------------------------------------------------------------------

# REQUIRED — absolute path to weewx.conf on the host.
WEEWX_CONF_PATH=/etc/weewx/weewx.conf

# REQUIRED for SQLite installs — absolute path to weewx.sdb on the host.
# MariaDB users: leave this unset or set to any placeholder; the api container
# ignores this mount when [database] kind = mariadb in api.conf.
WEEWX_DB_PATH=/var/lib/weewx/weewx.sdb

# ---------------------------------------------------------------------------
# Ports exposed to the host by Caddy
# ---------------------------------------------------------------------------

# Change these only if 80/443 are already in use on the host.
CLEARSKIES_HTTP_PORT=80
CLEARSKIES_HTTPS_PORT=443
