[Unit]
Description=weewx-clearskies-api
After=network.target

[Service]
Type=simple
User=clearskies
Group=clearskies
WorkingDirectory=/etc/weewx-clearskies
EnvironmentFile=/etc/weewx-clearskies/secrets.env
EnvironmentFile=-/etc/weewx-clearskies/network.env
ExecStart=/usr/local/bin/weewx-clearskies-api --bind ${CLEARSKIES_BIND_HOST:-0.0.0.0}
# If installed in a venv: ExecStart=/path/to/venv/bin/weewx-clearskies-api --bind ${CLEARSKIES_BIND_HOST:-0.0.0.0}
# CLEARSKIES_BIND_HOST is set by setup.sh in network.env:
#   IPv4 only:  0.0.0.0
#   IPv6 only:  ::
#   Dual-stack: *
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectSystem=strict
# The API caches processed weather data under /var/cache/weewx-clearskies.
# This exemption allows writes to that directory while keeping the rest of
# the filesystem read-only under ProtectSystem=strict.
ReadWritePaths=/var/cache/weewx-clearskies
# The ClearSkiesLoopRelay weewx extension writes loop.sock here; the API
# reads it via the direct adapter.
ReadWritePaths=/var/run/weewx-clearskies
PrivateTmp=true

[Install]
WantedBy=multi-user.target
