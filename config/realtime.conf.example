# DEPRECATED — clearskies-realtime has been merged into clearskies-api (ADR-058).
# The [input] and [units] settings that were here are now configured in api.conf.
# See the [input] and [units] sections in config/api.conf.example.
# This file is kept as a reference only. Do not deploy it.
#
# Clear Skies Realtime configuration (historical reference — deprecated)
# Format: configobj INI with subsections ([[name]] inside [section])

[input]
# "mqtt" — multi-host: realtime on a different host from weewx.
# "direct" — single-host: weewx on the same host, uses a Unix socket.
mode = mqtt

    [[mqtt]]
    broker_host = localhost
    broker_port = 1883
    topic = weewx/loop
    client_id = weewx-clearskies-realtime
    # username =
    # Password read from the env var named by password_env (set in secrets.env).
    password_env = WEEWX_CLEARSKIES_MQTT_PASSWORD
    tls = false
    # ca_file =
    qos = 0
    keepalive = 60

    [[direct]]
    socket_path = /var/run/weewx-clearskies/loop.sock

[sse]
# 0.0.0.0 = all IPv4 interfaces (reliable behind a reverse proxy).
# Do NOT use :: here: uvicorn sets IPV6_V6ONLY=1 on IPv6 sockets, so ::
# is IPv6-only regardless of the kernel net.ipv6.bindv6only setting.
# For MariaDB my.cnf, use bind-address = * (not ::) to bind all interfaces.
# Use 127.0.0.1 for loopback-only (same-host topology).
bind_host = 0.0.0.0
bind_port = 8766
# allowed_origins = *

[health]
bind_host = 127.0.0.1
bind_port = 8082

[logging]
# DEBUG, INFO, WARNING, ERROR. Env var CLEARSKIES_LOG_LEVEL overrides.
# level = INFO

[api]
# REQUIRED — upstream clearskies-api URL for BFF proxy mode (ADR-041).
#
# Caddy routes ALL /api/v1/* traffic to the realtime BFF (port 8766), which
# unit-converts responses before sending them to the dashboard.  The BFF must
# know where the upstream API lives.  If upstream_url is empty or missing,
# every /api/v1/* request returns 503 and THE WHOLE SITE FAILS.
#
# SINGLE-HOST (docker compose, single-host/): both services run as compose
# services on the same host.  Use the compose service name.  tls_verify is
# false because the API uses a self-signed certificate by default.
upstream_url = https://api:8765
tls_verify = false
#
# FRONTEND-HOST (docker compose, frontend-host/): realtime runs on the
# front-end host; the API runs on a separate weewx host.  Set upstream_url
# to the weewx host's external or LAN address.  Example:
# upstream_url = https://weewx-host.example.com:8765
# tls_verify = false
#
# NATIVE / REVERSE-PROXY (pip-installed, examples/reverse-proxy/):
# both services run as systemd units on the same host.  Example:
# upstream_url = https://localhost:8765
# tls_verify = false
#
# Upstream request timeout in seconds.
# timeout = 30
