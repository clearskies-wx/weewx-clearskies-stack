# Clear Skies API configuration
# Copy to api.conf in your deployment's config directory.
# Full reference: CONFIG.md in the stack repo.
#
# Secrets (DB password, API keys) belong in secrets.env, not here.
# Format: configobj INI (https://configobj.readthedocs.io/)

[api]
# Listen address — controls which network stack the API accepts connections on.
# Set by setup.sh based on your network configuration.
#   0.0.0.0  = IPv4 only (safest default for most home networks)
#   ::       = IPv6 only
#   *        = Dual-stack — both IPv4 and IPv6 (recommended if your network
#              and DNS support both families reliably)
# If unsure: many ISP-provided routers enable IPv6 via SLAAC but don't
# register local hostnames in IPv6 DNS. If Caddy can't reach the API,
# try switching to 0.0.0.0 (IPv4 only).
bind_host = *
bind_port = 8765
# max_request_bytes = 1048576
# cors_origins =

[health]
bind_host = 127.0.0.1
bind_port = 8081
# metrics_enabled = false

[logging]
# DEBUG, INFO, WARNING, ERROR. Env var CLEARSKIES_LOG_LEVEL overrides.
# level = INFO

[database]
kind = sqlite
path = /data/weewx.sdb

# MariaDB example (set kind = mysql):
# kind = mysql
# host = localhost
# port = 3306
# name = weewx
# pool_size = 5
# max_overflow = 10
# Credentials via secrets.env:
#   WEEWX_CLEARSKIES_DB_USER=weewx
#   WEEWX_CLEARSKIES_DB_PASSWORD=changeme

[weewx]
# conf_path = /etc/weewx/weewx.conf

[station]
# default_locale = en

[branding]
# site_title = My Weather Station
# logo_url =
# favicon_url =

[forecast]
# provider = nws
# Aeris forecast model: "standard" (/forecasts) or "xcast" (/xcast/forecasts,
# ML-enhanced temp/wind). Only applies when provider = aeris. Default: xcast.
# aeris_forecast_model = xcast

[alerts]
# provider = nws

[aqi]
# provider = airnow

[radar]
# provider = rainviewer

[tls]
# enabled = false
# cert_file =
# key_file =

[input]
# Loop-packet input source — replaces clearskies-realtime (ADR-058).
# "mqtt"   — multi-host or single-host via MQTT broker.
# "direct" — single-host: weewx on the same host, uses a Unix socket.
# mode = mqtt

    # [[mqtt]]
    # broker_host = localhost
    # broker_port = 1883
    # topic = weewx/loop
    # client_id = weewx-clearskies-api
    # username =
    # Password read from the env var named by password_env (set in secrets.env).
    # password_env = WEEWX_CLEARSKIES_MQTT_PASSWORD
    # tls = false
    # qos = 0
    # keepalive = 60

    # [[direct]]
    # socket_path = /var/run/weewx-clearskies/loop.sock

[units]
# Unit system for SSE loop-packet output — replaces clearskies-realtime (ADR-058).
# Matches the unit system your dashboard is configured to display.
# "metric"   — SI units (°C, m/s, hPa, mm).
# "us"       — US customary (°F, mph, inHg, in).
# "metricwx" — weewx MetricWX (°C, m/s, hPa, mm with wind in m/s).
# system = us
