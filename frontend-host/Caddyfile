{$CLEARSKIES_DOMAIN:localhost} {
    encode gzip

    handle /api/v1/* {
        reverse_proxy {$CLEARSKIES_API_URL}
    }

    handle /sse {
        reverse_proxy realtime:8766
    }

    handle {
        root * /srv/dashboard
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
