# Clear Skies — front-end host environment variables
# Copy to .env and fill in the required values.

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------

# REQUIRED — the public hostname Caddy will serve and obtain a TLS cert for.
# Use "localhost" for local testing (Caddy will use a self-signed cert).
CLEARSKIES_DOMAIN=weather.example.com

# ---------------------------------------------------------------------------
# API connection (cross-host)
# ---------------------------------------------------------------------------

# REQUIRED — URL of the Clear Skies API running on the weewx host.
# Caddy proxies /api/v1/* requests to this URL.
# Example: http://192.168.7.20:8765
CLEARSKIES_API_URL=http://WEEWX_HOST_IP:8765

# ---------------------------------------------------------------------------
# Image version
# ---------------------------------------------------------------------------
CLEARSKIES_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Config and secrets paths
# ---------------------------------------------------------------------------

# Directory containing realtime.conf. Mounted read-only into the realtime container.
CLEARSKIES_CONFIG_DIR=./config

# File containing runtime secrets (MQTT password, etc.).
CLEARSKIES_SECRETS_FILE=./config/secrets.env

# ---------------------------------------------------------------------------
# Ports exposed to the host by Caddy
# ---------------------------------------------------------------------------
CLEARSKIES_HTTP_PORT=80
CLEARSKIES_HTTPS_PORT=443
