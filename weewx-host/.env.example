# Clear Skies — weewx host environment variables
# Copy to .env and fill in the required values.

# ---------------------------------------------------------------------------
# Image version
# ---------------------------------------------------------------------------
CLEARSKIES_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Config and secrets paths
# ---------------------------------------------------------------------------

# Directory containing api.conf. Mounted read-only into the API container.
CLEARSKIES_CONFIG_DIR=./config

# File containing runtime secrets (DB password, API keys, etc.).
CLEARSKIES_SECRETS_FILE=./config/secrets.env

# ---------------------------------------------------------------------------
# weewx data paths (bind-mounted into the API container)
# ---------------------------------------------------------------------------

# REQUIRED — absolute path to weewx.conf on the host.
WEEWX_CONF_PATH=/etc/weewx/weewx.conf

# REQUIRED for SQLite — absolute path to weewx.sdb on the host.
# MariaDB users: leave unset or set to any placeholder.
WEEWX_DB_PATH=/var/lib/weewx/weewx.sdb

# Path to the weewx-clearskies socket directory on the host.
# The Loop Relay extension creates loop.sock here.
# Default: /var/run/weewx-clearskies
# WEEWX_SOCKET_DIR=/var/run/weewx-clearskies

# ---------------------------------------------------------------------------
# API port exposed to the host
# ---------------------------------------------------------------------------

# The port Caddy on the front-end host will connect to.
# Must be reachable from the front-end host over the network.
CLEARSKIES_API_PORT=8765

# ---------------------------------------------------------------------------
# Redis cache (optional — improves performance for provider API responses)
# ---------------------------------------------------------------------------

# Uncomment to enable persistent caching. With host networking, Redis
# is reachable on localhost.
# CLEARSKIES_CACHE_URL=redis://127.0.0.1:6379/0
