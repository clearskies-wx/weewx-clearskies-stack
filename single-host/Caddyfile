{$CLEARSKIES_DOMAIN:localhost} {
    encode gzip

    handle /api/v1/* {
        reverse_proxy api:8765
    }

    handle /sse {
        reverse_proxy api:8765
    }

    handle /wizard* {
        reverse_proxy config:9876
    }

    handle /bootstrap* {
        reverse_proxy config:9876
    }

    handle /login* {
        reverse_proxy config:9876
    }

    handle /logout* {
        reverse_proxy config:9876
    }

    handle /admin* {
        reverse_proxy config:9876
    }

    handle /static/* {
        reverse_proxy config:9876
    }

    handle /webcam.json {
        root * /etc/weewx-clearskies
        file_server
    }

    handle /branding.json {
        root * /etc/weewx-clearskies
        file_server
    }

    handle {
        root * /srv/dashboard
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
