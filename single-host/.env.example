# Clear Skies — single-host environment variables
# Copy to .env and fill in the required values.
# This file covers all four services running on one machine.

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------

# REQUIRED — the public hostname Caddy will serve and obtain a TLS cert for.
# Use "localhost" for local testing (Caddy will use a self-signed cert).
CLEARSKIES_DOMAIN=weather.example.com

# ---------------------------------------------------------------------------
# Image version
# ---------------------------------------------------------------------------
CLEARSKIES_VERSION=0.1.0

# ---------------------------------------------------------------------------
# Config and secrets paths
# ---------------------------------------------------------------------------

# Directory containing api.conf and realtime.conf.
# Mounted read-only into the api and realtime containers.
CLEARSKIES_CONFIG_DIR=./config

# File containing runtime secrets (API keys, DB password, MQTT password, etc.).
CLEARSKIES_SECRETS_FILE=./config/secrets.env

# ---------------------------------------------------------------------------
# weewx data paths (bind-mounted into the API container)
# ---------------------------------------------------------------------------

# REQUIRED — absolute path to weewx.conf on the host.
WEEWX_CONF_PATH=/etc/weewx/weewx.conf

# REQUIRED for SQLite — absolute path to weewx.sdb on the host.
# MariaDB users: leave unset or set to any placeholder.
WEEWX_DB_PATH=/var/lib/weewx/weewx.sdb

# ---------------------------------------------------------------------------
# Ports exposed to the host by Caddy
# ---------------------------------------------------------------------------
CLEARSKIES_HTTP_PORT=80
CLEARSKIES_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Redis cache (optional — improves performance for provider API responses)
# ---------------------------------------------------------------------------

# Uncomment to enable persistent caching. Uses Docker DNS name.
# CLEARSKIES_CACHE_URL=redis://redis:6379/0
