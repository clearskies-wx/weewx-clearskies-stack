# Copy to .env and fill in real values. .env is gitignored.

# --- MariaDB service (used by the `mariadb` profile) ----------------------
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=weewx
MARIADB_USER=weewx
MARIADB_PASSWORD=change-me-weewx
# Host-side port to expose MariaDB on (loopback only).
MARIADB_HOST_PORT=3307

# --- Read-only API user (created by mariadb-init/01-clearskies-ro.sql) ----
# The clearskies_ro user has SELECT-only on the weewx DB. The clearskies-api
# service and integration tests connect as this user (ADR-012). The password
# below matches the hard-coded value in 01-clearskies-ro.sql (dev/test only).
MARIADB_RO_PASSWORD=clearskies_ro_test
# DB URL for the API service and integration tests (MariaDB profile).
CLEARSKIES_DB_URL_RO=mysql+pymysql://clearskies_ro:clearskies_ro_test@127.0.0.1:${MARIADB_HOST_PORT:-3307}/weewx
# DB URL with write-capable seed user (used only for negative write-probe tests).
CLEARSKIES_DB_URL_RW=mysql+pymysql://${MARIADB_USER:-weewx}:change-me-weewx@127.0.0.1:${MARIADB_HOST_PORT:-3307}/weewx

# --- Production capture (used by snapshot/capture.py) ---------------------
# Connection string to the production weewx archive DB. The capture script
# reflects whatever schema is live there. See snapshot/README.md.
CAPTURE_SOURCE_URL=mysql+pymysql://weewx:REDACTED@127.0.0.1:3306/weewx
# Bound the snapshot to a date window (epoch seconds, inclusive). Empty = all rows.
CAPTURE_START_EPOCH=
CAPTURE_END_EPOCH=
